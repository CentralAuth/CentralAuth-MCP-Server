# Optional: enable admin-mode tools such as creating organizations and rotating secrets
CENTRALAUTH_API_KEY=
CENTRALAUTH_API_BASE_URL=https://centralauth.com/api

# Optional: override the CentralAuth auth base URL if you use a custom domain or subdomain
CENTRALAUTH_AUTH_BASE_URL=https://centralauth.com

# Optional: let the MCP server validate your app's OAuth-related env values in guidance output
CENTRALAUTH_CLIENT_ID=
CENTRALAUTH_CLIENT_SECRET=
CENTRALAUTH_CALLBACK_URL=
CENTRALAUTH_TIMEOUT_MS=15000
