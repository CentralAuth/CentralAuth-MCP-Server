{
  "name": "centralauth-mcp-server",
  "version": "0.3.0",
  "private": false,
  "type": "module",
  "description": "MCP server for AI-assisted CentralAuth integration guidance.",
  "repository": {
    "type": "git",
    "url": "https://github.com/CentralAuth/CentralAuth-MCP-Server.git"
  },
  "bin": {
    "centralauth-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "node --test --import tsx ./tests/**/*.test.ts",
    "inspector": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepack": "npm run build",
    "release:check": "npm run build && npm test && npm pack --dry-run"
  },
  "keywords": [
    "mcp",
    "centralauth",
    "authentication",
    "oauth"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.2.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}